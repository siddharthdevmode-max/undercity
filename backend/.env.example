# ============================================================
# BACKEND ENVIRONMENT VARIABLES — UNDERCITY
# Copy to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# ── Core ──────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://undercity:password@localhost:5432/undercity

# ── Redis ─────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
# REDIS_TLS=true  # enable in production

# ── Firebase Admin ────────────────────────────────────────
# Option 1: JSON string (recommended for production)
FIREBASE_SERVICE_ACCOUNT_JSON=
# Option 2: place firebase-service-account.json in backend/

# ── Cloudflare Turnstile ──────────────────────────────────
# Get from: Cloudflare Dashboard → Turnstile
# Dev: leave blank (bypass allowed)
# Prod: required
TURNSTILE_SECRET_KEY=

# ── Sentry ────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_RELEASE=undercity-backend@1.0.0
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Email (Resend) ────────────────────────────────────────
# Get from: resend.com → API Keys
RESEND_API_KEY=
EMAIL_FROM=noreply@undercity.online
EMAIL_PROVIDER=resend

# ── Alerts ────────────────────────────────────────────────
# Discord: Server Settings → Integrations → Webhooks
DISCORD_ALERT_WEBHOOK=
SLACK_ALERT_WEBHOOK=

# ── Security ──────────────────────────────────────────────
# Generate: openssl rand -base64 32
FINGERPRINT_SALT=

# ── CORS ──────────────────────────────────────────────────
# Prod: https://undercity.online,https://www.undercity.online
ALLOWED_ORIGINS=http://localhost:5173

# ── Admin UIDs ────────────────────────────────────────────
# Comma-separated Firebase UIDs
ADMIN_UIDS=
DEV_UIDS=
MODERATOR_UIDS=

# ── Rate Limiting ─────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=10

# ── Game Config ───────────────────────────────────────────
GAME_TICK_MS=60000
MAX_NERVE_DEFAULT=30
MAX_ENERGY_DEFAULT=100
ENERGY_REGEN_SEC=300
NERVE_REGEN_SEC=300

# ── Feature Flags ─────────────────────────────────────────
FEATURE_MAINTENANCE=false
FEATURE_REGISTRATION=true
FEATURE_PAYMENTS=false
FEATURE_VPN_CHECK=false
FEATURE_API_DOCS=true

# ── Payments (Phase 3 — not needed yet) ───────────────────
# LEMONSQUEEZY_API_KEY=
# LEMONSQUEEZY_STORE_ID=
# LEMONSQUEEZY_WEBHOOK_SECRET=
