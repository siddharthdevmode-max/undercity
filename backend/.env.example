# ============================================================
# UNDERCITY BACKEND — ENVIRONMENT TEMPLATE
# Copy this file to .env and fill in values
# ============================================================

NODE_ENV=development
PORT=5000

# Database
DATABASE_URL=postgresql://undercity:devpassword@postgres:5432/undercity?sslmode=disable

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=devredis

# Firebase (paste JSON content or leave empty if using file mount)
FIREBASE_SERVICE_ACCOUNT_JSON=

# Sentry (optional)
SENTRY_DSN=
SENTRY_RELEASE=undercity-backend@dev
SENTRY_TRACES_SAMPLE_RATE=0.1

# Payments — Lemon Squeezy (Phase 3)
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=

# Cloudflare Turnstile
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Fingerprint
FINGERPRINT_SALT=change-this-in-production-minimum-32-chars

# Alerts (optional)
DISCORD_ALERT_WEBHOOK=
SLACK_ALERT_WEBHOOK=

# Admin / Roles (Firebase UIDs, comma-separated)
ADMIN_UIDS=
DEV_UIDS=
MODERATOR_UIDS=

# CORS (production only)
ALLOWED_ORIGINS=

# Email
EMAIL_FROM=noreply@undercity.online
EMAIL_PROVIDER=console
EMAIL_API_KEY=

# Feature flags
FEATURE_MAINTENANCE=false
FEATURE_REGISTRATION=true
FEATURE_PAYMENTS=false
FEATURE_VPN_CHECK=false
FEATURE_API_DOCS=true
