# ════════════════════════════════════════════════════════════
# UNDERCITY BACKEND — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ════════════════════════════════════════════════════════════

# ─── Server ─────────────────────────────────────────────────
NODE_ENV=development
# development | production | test
PORT=5000

# ─── Database ───────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://undercity:yourpassword@localhost:5432/undercity_dev

# ─── Redis ──────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# Leave blank if no Redis password (local dev)
REDIS_PASSWORD=

# ─── Firebase ───────────────────────────────────────────────
# Option A: Path to service account JSON file (local dev)
# Just place firebase-service-account.json in backend/ root
# Option B: Paste the entire JSON as a single-line string (production)
FIREBASE_SERVICE_ACCOUNT_JSON=

# ─── CORS ───────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Admin ──────────────────────────────────────────────────
# Comma-separated Firebase UIDs that get admin access
# Emergency override — also set is_admin=true in DB
ADMIN_UIDS=

# ─── Cloudflare Turnstile ───────────────────────────────────
# Get from: https://dash.cloudflare.com → Turnstile
# Site key goes in frontend .env
TURNSTILE_SECRET_KEY=

# ─── Sentry Error Monitoring ────────────────────────────────
# Get from: https://sentry.io
# Leave blank to disable (app works without it)
SENTRY_DSN=
SENTRY_RELEASE=undercity-backend@1.0.0

# ─── Logging ────────────────────────────────────────────────
# error | warn | info | debug
LOG_LEVEL=info

# ─── Security ───────────────────────────────────────────────
# Countries to block (comma-separated ISO codes)
# Leave blank to allow all countries
BLOCKED_COUNTRIES=

# CSP violation reporting endpoint
# Leave blank to disable
CSP_REPORT_URI=

# ─── Alerts (optional) ──────────────────────────────────────
# Discord webhook for critical error alerts
DISCORD_ALERT_WEBHOOK=

# Slack webhook for critical error alerts
SLACK_ALERT_WEBHOOK=

# ════════════════════════════════════════════════════════════
# DOCKER ONLY (used by docker-compose)
# ════════════════════════════════════════════════════════════
POSTGRES_USER=undercity
POSTGRES_PASSWORD=yourpassword
POSTGRES_DB=undercity_dev
