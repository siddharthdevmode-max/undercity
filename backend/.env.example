# Server
PORT=5000
NODE_ENV=development
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/undercity

# Auth
JWT_SECRET=change-this-to-a-long-random-string-min-16-chars
JWT_EXPIRY=7d

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Admin - comma separated Firebase UIDs
ADMIN_UIDS=

# CORS - comma separated allowed origins (no trailing slashes)
ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com
