# ============================================================
# UNDERCITY BACKEND — ENV EXAMPLE
# Copy to .env and fill in values
# ============================================================

NODE_ENV=development
PORT=5000

# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=disable

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password

# Firebase
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Sentry
SENTRY_DSN=https://xxx@sentry.io/xxx
SENTRY_RELEASE=undercity-backend@1.0.0
SENTRY_TRACES_SAMPLE_RATE=0.1

# Stripe
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxx

# Cloudflare Turnstile
TURNSTILE_SECRET_KEY=your-secret-key

# Fingerprint
FINGERPRINT_SALT=minimum-32-char-random-string-here

# Alerts
DISCORD_ALERT_WEBHOOK=https://discord.com/api/webhooks/xxx
SLACK_ALERT_WEBHOOK=https://hooks.slack.com/xxx

# Admin UIDs (comma separated Firebase UIDs)
ADMIN_UIDS=uid1,uid2
DEV_UIDS=uid1
MODERATOR_UIDS=uid3,uid4

# CORS (comma separated)
ALLOWED_ORIGINS=https://undercity.gg,https://www.undercity.gg

# Rate limits
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=10

# Game config
GAME_TICK_MS=60000
MAX_NERVE_DEFAULT=30
ENERGY_REGEN_SEC=300
NERVE_REGEN_SEC=300

# Feature flags
FEATURE_MAINTENANCE=false
FEATURE_REGISTRATION=true
FEATURE_PAYMENTS=true
FEATURE_VPN_CHECK=true
FEATURE_API_DOCS=false

# Email
EMAIL_FROM=noreply@undercity.gg
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_xxx

# Security
BLOCKED_COUNTRIES=
CSP_REPORT_URI=
