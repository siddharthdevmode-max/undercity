# ============================================================
# UNDERCITY BACKEND — ENVIRONMENT VARIABLES
# ============================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git — it is in .gitignore
# All values marked REQUIRED must be set before server starts
# Values marked SWAP_ON_VPS: use placeholder now, swap when VPS ready
# ============================================================

# ── Core ──────────────────────────────────────────────────────
NODE_ENV=development
# SWAP_ON_VPS: production
PORT=5000

# ── Database ──────────────────────────────────────────────────
# REQUIRED
# Dev:  postgresql://undercity:devpassword@localhost:5432/undercity
# Prod: postgresql://undercity:STRONG_PASSWORD@postgres:5432/undercity?sslmode=require
DATABASE_URL=postgresql://undercity:devpassword@localhost:5432/undercity
# Pool sizing — tune for 1000 concurrent users
# DATABASE_POOL_MAX=75
# DATABASE_POOL_MIN=5
# DATABASE_POOL_ACQUIRE_MS=10000

# ── Redis ─────────────────────────────────────────────────────
# REQUIRED
# Dev:  localhost
# Prod (Docker): redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REQUIRED — set a strong password in production
REDIS_PASSWORD=devredis
# SWAP_ON_VPS: uncomment
# REDIS_TLS=true

# ── PostgreSQL (for Docker Compose only) ──────────────────────
POSTGRES_USER=undercity
POSTGRES_PASSWORD=devpassword
POSTGRES_DB=undercity

# ── Firebase Admin SDK ────────────────────────────────────────
# REQUIRED
# Option 1 (recommended for production): paste the full JSON as a string
# Option 2 (dev): place firebase-service-account.json in backend/
# Get from: Firebase Console → Project Settings → Service Accounts
FIREBASE_SERVICE_ACCOUNT_JSON=

# ── Cloudflare Turnstile ──────────────────────────────────────
# Dev: leave blank — bypass is allowed in development
# Prod: REQUIRED — get from Cloudflare Dashboard → Turnstile
# SWAP_ON_VPS: set real key
TURNSTILE_SECRET_KEY=

# ── Sentry (Error Monitoring) ─────────────────────────────────
# Optional in dev, REQUIRED in prod
# Get from: sentry.io → Project → Settings → Client Keys
# SWAP_ON_VPS: set real DSN
SENTRY_DSN=
SENTRY_RELEASE=undercity-backend@1.0.0
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Email (Resend) ────────────────────────────────────────────
# Optional in dev (emails logged to console if key missing)
# REQUIRED in prod
# Get from: resend.com → API Keys
# SWAP_ON_VPS: set real key
RESEND_API_KEY=
EMAIL_FROM=noreply@undercity.online
EMAIL_PROVIDER=resend

# ── Alerts ────────────────────────────────────────────────────
# Optional — alerts fire to Discord/Slack on critical events
# Create: Discord Server → Integrations → Webhooks
DISCORD_ALERT_WEBHOOK=
SLACK_ALERT_WEBHOOK=

# ── App URL ───────────────────────────────────────────────────
# SWAP_ON_VPS: set to https://undercity.online
APP_URL=http://localhost:5173

# ── CORS ──────────────────────────────────────────────────────
# Dev: Vite dev server
# Prod: SWAP_ON_VPS: https://undercity.online,https://www.undercity.online
ALLOWED_ORIGINS=http://localhost:5173

# ── Security ──────────────────────────────────────────────────
# REQUIRED — generate with: openssl rand -base64 32
# SWAP_ON_VPS: generate fresh value
FINGERPRINT_SALT=dev-salt-change-in-production-minimum-32-chars

# ── Admin + Role UIDs ─────────────────────────────────────────
# Comma-separated Firebase UIDs
# Find your UID: Firebase Console → Authentication → Users
ADMIN_UIDS=
DEV_UIDS=
MODERATOR_UIDS=

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=10

# ── Game Config ───────────────────────────────────────────────
GAME_TICK_MS=60000
MAX_NERVE_DEFAULT=30
MAX_ENERGY_DEFAULT=100
ENERGY_REGEN_SEC=300
NERVE_REGEN_SEC=300

# ── Feature Flags ─────────────────────────────────────────────
# Flip these without code changes
FEATURE_MAINTENANCE=false
FEATURE_REGISTRATION=true
FEATURE_PAYMENTS=false
FEATURE_VPN_CHECK=false
FEATURE_API_DOCS=true

# ── Payments (Phase 11 — September 2026) ──────────────────────
# Leave blank until Phase 11
# SWAP_ON_VPS: set when Lemon Squeezy account created
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=

# ── Payments — Razorpay (India, Phase 11) ─────────────────────
# Leave blank until Phase 11
# SWAP_ON_VPS: set when Razorpay account created
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── Payments — Lemon Squeezy Variant IDs (Phase 11) ───────────
# Get from: Lemon Squeezy Dashboard → Products → Variants
# SWAP_ON_VPS: set when products created in LS dashboard
LEMONSQUEEZY_BLACK_CARD_VARIANT_ID=
LEMONSQUEEZY_CONTRIBUTOR_VARIANT_ID=
LEMONSQUEEZY_BLACK_CARD_URL=
LEMONSQUEEZY_CONTRIBUTOR_URL=

# ── Database SSL (Phase 16 — VPS Setup) ───────────────────────
# Hetzner private network: DATABASE_SSL=false (default)
# Managed DB (Supabase, RDS): DATABASE_SSL=true
# SWAP_ON_VPS: set based on your DB provider
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=true
