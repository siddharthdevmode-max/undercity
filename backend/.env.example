# ════════════════════════════════════════════════════════════
# UNDERCITY BACKEND ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values
# Never commit .env to git
# ════════════════════════════════════════════════════════════

# ─── Server ───
PORT=5000
NODE_ENV=development

# ─── Database ───
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://undercity_user:undercity123@localhost:5432/undercity

# ─── Redis ───
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Logging ───
LOG_LEVEL=info

# ─── Admin UIDs ───
# Comma-separated Firebase UIDs that have admin access
# Get UID from Firebase Console > Authentication > Users
ADMIN_UIDS=

# ─── CORS ───
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,https://undercity.pages.dev

# ─── Firebase Admin SDK ───
# OPTION 1: Inline JSON (recommended for production/CI)
# Paste the entire service account JSON as a single line
FIREBASE_SERVICE_ACCOUNT_JSON=

# OPTION 2: File path (local dev only)
# Place firebase-service-account.json in the backend/ directory
# The file is gitignored — never commit it
