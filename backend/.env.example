# ════════════════════════════════════════════════════════════
# UNDERCITY BACKEND ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values
# ════════════════════════════════════════════════════════════

# Server
PORT=5000
NODE_ENV=development

# PostgreSQL Database
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/undercity

# JWT Secret (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Logging
LOG_LEVEL=info

# Admin Firebase UIDs (comma separated)
ADMIN_UIDS=

# CORS allowed origins (comma separated)
ALLOWED_ORIGINS=http://localhost:5173

# ════════════════════════════════════════════════════════════
# FIREBASE SERVICE ACCOUNT — Two options:
# ════════════════════════════════════════════════════════════
#
# OPTION A (Production — Render/Railway/Cloud):
#   Paste the entire JSON contents as a single line string here.
#   This is the SECURE method — no file on disk.
#
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...",...}
#
# OPTION B (Local development):
#   Download JSON from Firebase Console > Project Settings > Service Accounts
#   Save as: backend/firebase-service-account.json (gitignored)
#   Set chmod 600 for security: chmod 600 backend/firebase-service-account.json
#
# Priority order in code:
#   1. FIREBASE_SERVICE_ACCOUNT_JSON env var (if set)
#   2. firebase-service-account.json file (fallback for local dev)
#   3. Skipped if NODE_ENV=test (CI mock)
# ════════════════════════════════════════════════════════════
