# ============================================================
# UNDERCITY BACKEND — ENVIRONMENT VARIABLES
# Copy to .env and fill in values
# NEVER commit .env to git
# ============================================================

# ── Server ───────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://undercity_user:CHANGE_ME@localhost:5432/undercity_db
POSTGRES_USER=undercity_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=undercity_db

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,https://undercity.app

# ── Admin UIDs ────────────────────────────────────────────────
# Comma-separated Firebase UIDs for admin access
ADMIN_UIDS=your_firebase_uid_here

# ── Firebase ──────────────────────────────────────────────────
# Option 1: JSON string (production/Render)
FIREBASE_SERVICE_ACCOUNT_JSON=

# Option 2: File path (local dev only — never commit the file)
# Place firebase-service-account.json in backend/ folder

# ── Cloudflare Turnstile ──────────────────────────────────────
TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# ── Stripe ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_HUSTLER=price_xxx
STRIPE_PRICE_KINGPIN=price_xxx
STRIPE_PRICE_OVERLORD=price_xxx

# ── Email (Resend) ─────────────────────────────────────────────
RESEND_API_KEY=re_your_key
EMAIL_FROM=noreply@undercity.app

# ── Sentry ───────────────────────────────────────────────────
SENTRY_DSN=https://your_key@sentry.io/your_project
SENTRY_RELEASE=undercity-backend@1.0.0

# ── Alerts ───────────────────────────────────────────────────
DISCORD_ALERT_WEBHOOK=https://discord.com/api/webhooks/xxx/xxx
SLACK_ALERT_WEBHOOK=https://hooks.slack.com/services/xxx/xxx/xxx
# Set to "true" to force alerts in dev (for testing)
FORCE_ALERTS=false

# ── Security ──────────────────────────────────────────────────
# Comma-separated ISO country codes to block
BLOCKED_COUNTRIES=
# CSP violation reporting endpoint
CSP_REPORT_URI=https://your_csp_report_uri

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=info
