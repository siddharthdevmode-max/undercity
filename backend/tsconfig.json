{
  "compilerOptions": {
    "target":                          "ES2020",
    "module":                          "commonjs",
    "lib":                             ["ES2020"],
    "outDir":                          "./dist",
    "rootDir":                         "./src",
    "strict":                          true,
    "esModuleInterop":                 true,
    "skipLibCheck":                    true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule":               true,
    "declaration":                     true,
    "declarationMap":                  false,
    "sourceMap":                       true,
    "moduleResolution":                "node",
    "allowSyntheticDefaultImports":    true,
    "noUnusedLocals":                  true,
    "noUnusedParameters":              true,
    "noImplicitReturns":               true,
    "noFallthroughCasesInSwitch":      true
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/integration/**/*",
    "src/test-utils/**/*",
    "src/__tests__/**/*"
  ]
}
