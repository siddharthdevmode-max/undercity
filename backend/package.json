{
  "name": "backend",
  "private": true,
  "version": "1.0.0",
  "license": "BUSL-1.1",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "migrate": "node-pg-migrate up",
    "migrate:down": "node-pg-migrate down",
    "seed:crimes": "node dist/scripts/seedCrimes.js",
    "seed:specials": "node dist/scripts/seedSpecials.js",
    "db:reset": "npm run migrate:down && npm run migrate && npm run seed:crimes",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:all": "vitest run && vitest run --config vitest.integration.config.ts",
    "lint": "eslint --max-warnings 0 src",
    "lint:fix": "eslint --max-warnings 0 src --fix",
    "audit:check": "npm audit --audit-level=high",
    "audit:report": "npm audit --json > audit-report.json || true"
  },
  "dependencies": {
    "@lemonsqueezy/lemonsqueezy.js": "^4.0.0",
    "@sentry/node": "^10.56.0",
    "bullmq": "^5.0.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.18.0",
    "express-rate-limit": "^8.5.2",
    "firebase-admin": "^12.0.0",
    "helmet": "^8.2.0",
    "ioredis": "^5.0.0",
    "morgan": "^1.11.0",
    "node-pg-migrate": "^8.0.4",
    "on-finished": "^2.4.1",
    "pg": "^8.11.0",
    "rate-limit-redis": "^5.0.0",
    "resend": "^6.12.4",
    "socket.io": "^4.8.3",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.9.2",
    "@types/on-finished": "^2.3.5",
    "@types/pg": "^8.10.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.8",
    "@vitest/ui": "^4.1.8",
    "eslint": "^10.4.1",
    "license-checker": "^25.0.1",
    "supertest": "^7.2.2",
    "tsx": "^4.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8"
  }
}
