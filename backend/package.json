{
  "name": "undercity",
  "version": "1.0.0",
  "description": "A browser-based crime MMO inspired by Torn. Build your criminal empire, commit crimes, train stats, and dominate the underground.",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "seed:crimes": "ts-node src/scripts/seedCrimes.ts",
    "seed:specials": "ts-node src/scripts/seedSpecials.ts",
    "backup": "ts-node src/scripts/backupDatabase.ts",
    "trust:recovery": "ts-node src/scripts/runTrustRecovery.ts",
    "clean:idempotency": "ts-node src/scripts/cleanIdempotencyKeys.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/siddharthdevmode-max/undercity.git"
  },
  "license": "BUSL-1.1",
  "bugs": {
    "url": "https://github.com/siddharthdevmode-max/undercity/issues"
  },
  "homepage": "https://github.com/siddharthdevmode-max/undercity#readme",
  "dependencies": {
    "@lemonsqueezy/lemonsqueezy.js": "^4.0.0",
    "@sentry/node": "^8.0.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "express-rate-limit": "^7.0.0",
    "firebase-admin": "^12.0.0",
    "helmet": "^7.0.0",
    "ioredis": "^5.0.0",
    "knex": "^3.0.0",
    "pg": "^8.11.0",
    "socket.io": "^4.7.0",
    "winston": "^3.11.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/on-finished": "^2.3.5",
    "@types/pg": "^8.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "eslint": "^8.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "ts-node": "^10.9.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
