{
  "name": "undercity-backend",
  "version": "1.0.0",
  "description": "Undercity — browser-based crime MMO backend. Node.js + TypeScript + PostgreSQL + Redis.",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev":                "ts-node-dev --respawn --transpile-only src/server.ts",
    "build":              "tsc",
    "start":              "node dist/server.js",
    "start:cluster":      "node dist/cluster.js",
    "lint":               "eslint src",
    "lint:fix":           "eslint src --fix",
    "test":               "vitest run --config vitest.config.ts",
    "test:watch":         "vitest --config vitest.config.ts",
    "test:coverage":      "vitest run --config vitest.config.ts --coverage",
    "test:integration":   "vitest run --config vitest.integration.config.ts",
    "seed:crimes":        "ts-node src/scripts/seedCrimes.ts",
    "seed:specials":      "ts-node src/scripts/seedSpecials.ts",
    "backup":             "ts-node src/scripts/backupDatabase.ts",
    "trust:recovery":     "ts-node src/scripts/runTrustRecovery.ts",
    "clean:idempotency":  "ts-node src/scripts/cleanIdempotencyKeys.ts",
    "reset:users":        "ts-node src/scripts/resetUsersForLaunch.ts"
  },
  "license": "BUSL-1.1",
  "dependencies": {
    "@lemonsqueezy/lemonsqueezy.js": "^4.0.0",
    "@sentry/node":                  "^8.0.0",
    "bullmq":                        "^5.0.0",
    "cors":                          "^2.8.5",
    "dotenv":                        "^16.0.0",
    "express":                       "^4.18.0",
    "express-rate-limit":            "^7.0.0",
    "firebase-admin":                "^12.0.0",
    "helmet":                        "^7.0.0",
    "ioredis":                       "^5.0.0",
    "knex":                          "^3.0.0",
    "pg":                            "^8.11.0",
    "rate-limit-redis":              "^4.2.0",
    "resend":                        "^4.0.0",
    "socket.io":                     "^4.7.0",
    "winston":                       "^3.11.0",
    "winston-daily-rotate-file":     "^5.0.0",
    "zod":                           "^3.22.0"
  },
  "devDependencies": {
    "@commitlint/cli":                    "^19.0.0",
    "@commitlint/config-conventional":    "^19.0.0",
    "@types/cors":                        "^2.8.17",
    "@types/express":                     "^4.17.21",
    "@types/node":                        "^20.11.0",
    "@types/on-finished":                 "^2.3.5",
    "@types/pg":                          "^8.11.0",
    "@types/supertest":                   "^6.0.0",
    "@vitest/coverage-v8":               "^2.0.0",
    "eslint":                             "^9.0.0",
    "typescript-eslint":                  "^8.0.0",
    "husky":                              "^9.0.0",
    "lint-staged":                        "^15.0.0",
    "prettier":                           "^3.0.0",
    "supertest":                          "^7.0.0",
    "ts-node":                            "^10.9.0",
    "ts-node-dev":                        "^2.0.0",
    "typescript":                         "^5.3.0",
    "vitest":                             "^2.0.0"
  },
  "repository": {
    "type": "git",
    "url":  "git+https://github.com/siddharthdevmode-max/undercity.git"
  },
  "bugs": {
    "url": "https://github.com/siddharthdevmode-max/undercity/issues"
  },
  "homepage": "https://github.com/siddharthdevmode-max/undercity#readme"
}
