{
  "name": "backend",
  "version": "1.0.0",
  "description": "Undercity backend - Crime MMO API",
  "main": "dist/app.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only --exit-child src/app.ts",
    "build": "npm run lint && tsc",
    "start": "node dist/app.js",
    "test": "vitest run",
    "migrate": "node-pg-migrate up",
    "migrate:down": "node-pg-migrate down",
    "migrate:create": "node-pg-migrate create",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "backup": "ts-node src/scripts/backupDatabase.ts",
    "dev:slow": "ts-node src/app.ts",
    "lint": "eslint src --max-warnings 100"
  },
  "keywords": [
    "mmo",
    "crime",
    "game",
    "api"
  ],
  "author": "Challenger_69",
  "license": "ISC",
  "dependencies": {
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "firebase-admin": "^13.10.0",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.0",
    "morgan": "^1.10.1",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.21.0",
    "swagger-ui-express": "^5.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "uuid": "^14.0.0",
    "winston": "^3.19.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/morgan": "^1.9.10",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^11.0.0",
    "@vitest/ui": "^4.1.8",
    "eslint": "^10.4.1",
    "supertest": "^7.2.2",
    "ts-node-dev": "^2.0.0",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.8"
  }
}
