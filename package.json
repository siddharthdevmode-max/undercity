{
  "name": "undercity",
  "version": "1.0.0",
  "description": "A browser-based crime MMO inspired by Torn.",
  "private": true,
  "scripts": {
    "prepare":          "husky",
    "test":             "cd backend && npx vitest run",
    "test:integration": "cd backend && npx vitest run --config vitest.integration.config.ts",
    "test:all":         "cd backend && npx vitest run && npx vitest run --config vitest.integration.config.ts",
    "build:backend":    "cd backend && npm run build",
    "build:frontend":   "cd frontend && npm run build",
    "lint:backend":     "cd backend && npm run lint",
    "lint:frontend":    "cd frontend && npm run lint"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/siddharthdevmode-max/undercity.git"
  },
  "license": "ISC",
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@types/on-finished": "^2.3.5",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3"
  },
  "dependencies": {
    "@lemonsqueezy/lemonsqueezy.js": "^4.0.0"
  }
}
