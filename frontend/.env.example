# ════════════════════════════════════════════════════════════
# UNDERCITY FRONTEND — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ════════════════════════════════════════════════════════════

# ─── Backend API ────────────────────────────────────────────
VITE_API_URL=http://localhost:5000

# ─── Firebase ───────────────────────────────────────────────
# Get from: Firebase Console → Project Settings → Your Apps
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ─── Cloudflare Turnstile ───────────────────────────────────
# Get from: https://dash.cloudflare.com → Turnstile
# This is the PUBLIC site key (safe to expose)
VITE_TURNSTILE_SITE_KEY=

# ─── FingerprintJS ──────────────────────────────────────────
# Get from: https://dashboard.fingerprint.com
# Leave blank to use free open-source version
VITE_FPJS_API_KEY=

# ─── Sentry ─────────────────────────────────────────────────
# Frontend DSN (different from backend DSN)
# Leave blank to disable
VITE_SENTRY_DSN=

# ─── Feature Flags ──────────────────────────────────────────
# Set to true to enable features in development
VITE_ENABLE_DEV_TOOLS=true
