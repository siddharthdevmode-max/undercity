# ============================================================
# FRONTEND ENVIRONMENT VARIABLES — UNDERCITY
# Copy to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# ── API ───────────────────────────────────────────────────
# Dev:  leave blank — Vite proxy handles /api automatically
# Prod: https://api.undercity.online/api
VITE_API_URL=

# ── Firebase ──────────────────────────────────────────────
# Get from: Firebase Console → Project Settings → Your apps
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# ── Cloudflare Turnstile ──────────────────────────────────
# Get from: Cloudflare Dashboard → Turnstile → site key
# Dev:  leave blank (widget won't show, bypass allowed)
# Prod: required (starts with 0x...)
VITE_TURNSTILE_SITE_KEY=

# ── Sentry (frontend) ─────────────────────────────────────
# Get from: sentry.io → Project → DSN
VITE_SENTRY_DSN=
VITE_SENTRY_RELEASE=undercity-frontend@1.0.0

# ── PostHog analytics ─────────────────────────────────────
# Get from: app.posthog.com → Project → API key
# Optional — leave blank to disable analytics
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://app.posthog.com

# ── Build ─────────────────────────────────────────────────
# Enable source maps in production build (true/false)
VITE_SOURCEMAP=false
